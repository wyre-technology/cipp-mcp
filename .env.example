# CIPP MCP Server Configuration
CIPP_BASE_URL=https://cipp.yourdomain.com
CIPP_API_KEY=your-api-key-here

# Transport: stdio (default for Claude Desktop) or http (for gateway/remote use)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Auth mode: env (default) or gateway (for MCP gateway deployments)
AUTH_MODE=env

# Logging
LOG_LEVEL=info
LOG_FORMAT=simple
