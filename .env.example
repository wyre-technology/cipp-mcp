# CIPP MCP Server Configuration
CIPP_BASE_URL=https://cipp.yourdomain.com

# --- Authentication (choose ONE) -------------------------------------------
#
# Option A: Static Bearer token. Leave commented out if using OAuth below.
# CIPP_API_KEY=your-api-key-here
#
# Option B: OAuth 2.0 client-credentials against Entra ID. This is what the
# CIPP "API Clients" integration page issues — a client ID + secret registered
# in your CIPP tenant. The MCP server exchanges them for a short-lived access
# token on each request and caches it until expiry.
# CIPP_TENANT_ID=00000000-0000-0000-0000-000000000000
# CIPP_CLIENT_ID=00000000-0000-0000-0000-000000000000
# CIPP_CLIENT_SECRET=your-client-secret-value
# CIPP_TOKEN_SCOPE=api://<sam-app-id>/.default   # defaults to <clientId>/.default
# CIPP_TOKEN_URL=                                # override only for sovereign clouds

# Transport: stdio (default for Claude Desktop) or http (for gateway/remote use)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Auth mode: env (default) or gateway (for MCP gateway deployments)
AUTH_MODE=env

# Logging
LOG_LEVEL=info
LOG_FORMAT=simple
